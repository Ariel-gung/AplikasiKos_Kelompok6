<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scroll_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Welcome Header Card -->
        <LinearLayout
            android:id="@+id/card_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="2dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tv_welcome_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selamat Datang,"
                android:textSize="14sp"
                android:textColor="#5F6368" />

            <TextView
                android:id="@+id/tv_user_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ariel Athaillah"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#202124"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_role_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Role: Pencari Kos"
                android:textSize="11sp"
                android:textColor="#1A73E8"
                android:background="#E8f0fe"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp" />
        </LinearLayout>

        <!-- Search Bar Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <EditText
                android:id="@+id/et_search_kamar"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Cari lokasi, tipe, atau harga kos..."
                android:textSize="14sp"
                android:textColor="#202124"
                android:inputType="text" />

            <ImageView
                android:id="@+id/btn_search"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_search"
                android:contentDescription="Tombol Cari" />
        </LinearLayout>

        <!-- Section Title: Kamar Tersedia -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Daftar Kamar Terpopuler"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#202124"
            android:layout_marginBottom="12dp" />

        <!-- Listing 1 (Kamar Card) -->
        <LinearLayout
            android:id="@+id/card_kamar_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <!-- Room Image Placeholder -->
            <ImageView
                android:id="@+id/img_kamar_1"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery"
                android:background="#E8EAED"
                android:contentDescription="Foto Kamar Deluxe"
                android:layout_marginBottom="12dp" />

            <!-- Room Title & Tipe -->
            <TextView
                android:id="@+id/tv_kamar_title_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kamar 102 - Tipe Deluxe"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#202124"
                android:layout_marginBottom="4dp" />

            <!-- Room Location / Facilities -->
            <TextView
                android:id="@+id/tv_kamar_facility_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AC, WiFi, Kamar Mandi Dalam, Kasur Queen Size"
                android:textSize="12sp"
                android:textColor="#5F6368"
                android:layout_marginBottom="8dp" />

            <!-- Room Price & Status -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tv_kamar_price_1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Rp 1.500.000 / bln"
                    android:textSize="14sp"
                    android:textColor="#D93025"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_kamar_status_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tersedia"
                    android:textSize="11sp"
                    android:textColor="#34A853"
                    android:background="#E6F4EA"
                    android:paddingLeft="6dp"
                    android:paddingRight="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp" />
            </LinearLayout>

            <!-- Book Button -->
            <Button
                android:id="@+id/btn_pesan_kamar_1"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="Pesan Sekarang"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1A73E8"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Listing 2 (Kamar Card) -->
        <LinearLayout
            android:id="@+id/card_kamar_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <!-- Room Image Placeholder -->
            <ImageView
                android:id="@+id/img_kamar_2"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery"
                android:background="#E8EAED"
                android:contentDescription="Foto Kamar Standar"
                android:layout_marginBottom="12dp" />

            <!-- Room Title & Tipe -->
            <TextView
                android:id="@+id/tv_kamar_title_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kamar 105 - Tipe Standar"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#202124"
                android:layout_marginBottom="4dp" />

            <!-- Room Location / Facilities -->
            <TextView
                android:id="@+id/tv_kamar_facility_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kipas Angin, WiFi, Kamar Mandi Luar, Kasur Single"
                android:textSize="12sp"
                android:textColor="#5F6368"
                android:layout_marginBottom="8dp" />

            <!-- Room Price & Status -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tv_kamar_price_2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Rp 850.000 / bln"
                    android:textSize="14sp"
                    android:textColor="#D93025"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_kamar_status_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tersedia"
                    android:textSize="11sp"
                    android:textColor="#34A853"
                    android:background="#E6F4EA"
                    android:paddingLeft="6dp"
                    android:paddingRight="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp" />
            </LinearLayout>

            <!-- Book Button -->
            <Button
                android:id="@+id/btn_pesan_kamar_2"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="Pesan Sekarang"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1A73E8"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
